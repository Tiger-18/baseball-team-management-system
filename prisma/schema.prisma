generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id              Int             @id @default(autoincrement())
  name            String
  jerseyNumber    String          @map("jersey_number")
  primaryPosition String?         @map("primary_position")
  isPitcher       Boolean         @default(false) @map("is_pitcher")
  birthDate       DateTime?       @map("birth_date")
  joinDate        DateTime?       @map("join_date")
  contactPhone    String?         @map("contact_phone")
  positions       PlayerPosition[]
  fielderProfile  FielderProfile?
  pitcherProfile  PitcherProfile?
  gameRecords     GameRecord[]

  @@map("players")
}

model Position {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  players     PlayerPosition[]

  @@map("positions")
}

model PlayerPosition {
  playerId   Int      @map("player_id")
  positionId Int      @map("position_id")
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([playerId, positionId])
  @@map("player_positions")
}

model FielderProfile {
  playerId                  Int      @id @map("player_id")
  atBatsTotal               Int      @default(0) @map("at_bats_total")
  runsTotal                 Int      @default(0) @map("runs_total")
  hitsTotal                 Int      @default(0) @map("hits_total")
  rbiTotal                  Int      @default(0) @map("rbi_total")
  walksTotal                Int      @default(0) @map("walks_total")
  strikeoutsBattingTotal    Int      @default(0) @map("strikeouts_batting_total")
  battingAverage            Float    @default(0) @map("batting_average")
  onBasePercentage          Float    @default(0) @map("on_base_percentage")
  sluggingPercentage        Float    @default(0) @map("slugging_percentage")
  ops                       Float    @default(0)
  doubles                   Int      @default(0)
  triples                   Int      @default(0)
  homeRunsBatting           Int      @default(0) @map("home_runs_batting")
  totalBases                Int      @default(0) @map("total_bases")
  hitByPitch                Int      @default(0) @map("hit_by_pitch")
  stolenBases               Int      @default(0) @map("stolen_bases")
  caughtStealing            Int      @default(0) @map("caught_stealing")
  sacrificeFlys             Int      @default(0) @map("sacrifice_flys")
  sacrificeHits             Int      @default(0) @map("sacrifice_hits")
  errorsFielding            Int      @default(0) @map("errors_fielding")
  passedBalls               Int      @default(0) @map("passed_balls")
  player                    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("fielder_profiles")
}

model PitcherProfile {
  playerId               Int      @id @map("player_id")
  inningsPitchedTotal    Float    @default(0) @map("innings_pitched_total")
  hitsAllowedTotal       Int      @default(0) @map("hits_allowed_total")
  runsAllowedTotal       Int      @default(0) @map("runs_allowed_total")
  earnedRunsTotal        Int      @default(0) @map("earned_runs_total")
  walksAllowedTotal      Int      @default(0) @map("walks_allowed_total")
  strikeoutsTotal        Int      @default(0) @map("strikeouts_total")
  homeRunsAllowedTotal   Int      @default(0) @map("home_runs_allowed_total")
  pitches                Int      @default(0)
  strikes                Int      @default(0)
  hitByPitchAllowed      Int      @default(0) @map("hit_by_pitch_allowed")
  battersFaced           Int      @default(0) @map("batters_faced")
  era                    Float    @default(0)
  whip                   Float    @default(0)
  strikePercentage       Float    @default(0) @map("strike_percentage")
  wildPitches            Int      @default(0) @map("wild_pitches")
  player                 Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("pitcher_profiles")
}

model GameRecord {
  id                 Int       @id @default(autoincrement())
  playerId           Int       @map("player_id")
  gameDate           DateTime  @map("game_date")
  opponent           String?
  isPitchingRecord   Boolean   @default(false) @map("is_pitching_record")
  atBats             Int       @default(0) @map("at_bats")
  runs               Int       @default(0)
  hits               Int       @default(0)
  rbi                Int       @default(0)
  walks              Int       @default(0)
  strikeouts         Int       @default(0)
  doubles            Int       @default(0)
  triples            Int       @default(0)
  homeRunsBatting    Int       @default(0) @map("home_runs_batting")
  totalBases         Int       @default(0) @map("total_bases")
  hitByPitch         Int       @default(0) @map("hit_by_pitch")
  stolenBases        Int       @default(0) @map("stolen_bases")
  caughtStealing     Int       @default(0) @map("caught_stealing")
  sacrificeFlys      Int       @default(0) @map("sacrifice_flys")
  sacrificeHits      Int       @default(0) @map("sacrifice_hits")
  pitches            Int       @default(0)
  strikes            Int       @default(0)
  hitByPitchAllowed  Int       @default(0) @map("hit_by_pitch_allowed")
  battersFaced       Int       @default(0) @map("batters_faced")
  wildPitches        Int       @default(0) @map("wild_pitches")
  inningsPitched     Float     @default(0) @map("innings_pitched")
  hitsAllowed        Int       @default(0) @map("hits_allowed")
  runsAllowed        Int       @default(0) @map("runs_allowed")
  earnedRuns         Int       @default(0) @map("earned_runs")
  walksAllowed       Int       @default(0) @map("walks_allowed")
  strikeoutsPitched  Int       @default(0) @map("strikeouts_pitched")
  homeRunsAllowed    Int       @default(0) @map("home_runs_allowed")
  errorsFielding     Int       @default(0) @map("errors_fielding")
  passedBalls        Int       @default(0) @map("passed_balls")
  win                Boolean   @default(false)
  loss               Boolean   @default(false)
  save               Boolean   @default(false)
  player             Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("game_records")
}
